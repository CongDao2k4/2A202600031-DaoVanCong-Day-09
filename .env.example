# Day 09 Lab — Environment Variables
# Copy file này thành .env và điền giá trị thật:
#   cp .env.example .env

# ─── Chọn 1 trong 2 LLM provider ───

# Option A: OpenAI (GPT-4o-mini hoặc GPT-4o)
# Hoặc OpenAI-compatible endpoint (LM Studio, Ollama, vLLM, v.v.)
OPENAI_API_KEY=sk-...your-key-here...

# OpenAI-compatible Base URL (optional - dùng cho LM Studio, local LLM)
# LM Studio mặc định: http://localhost:1234/v1
# Ollama: http://localhost:11434/v1
OPENAI_BASE_URL=https://pro-chicken-luckily.ngrok-free.app/v1

# OpenAI-compatible Model Name (optional - mặc định: gpt-4o-mini)
# Chỉ định model name khi dùng local LLM / LM Studio
OPENAI_MODEL=nvidia/nemotron-3-nano-4b

# OpenAI-compatible Embedding Model (optional - mặc định: text-embedding-3-small)
# Dùng cho LM Studio: cần load embedding model trong LM Studio UI (Embeddings tab)
# Ví dụ: nomic-embed-text, all-MiniLM-L6-v2, text-embedding-ada-002
OPENAI_EMBEDDING_MODEL=text-embedding-qwen3-embedding-0.6b

# Option B: Google Gemini
# GOOGLE_API_KEY=AI...your-key-here...

# ─── Cấu hình ChromaDB ───
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day09_docs

# ─── Cấu hình Retrieval ───
RETRIEVAL_TOP_K=3

# ─── Cấu hình MCP (Sprint 3 - optional) ───
# MCP_SERVER_URL=http://localhost:8080
# MCP_SERVER_MODE=mock   # hoặc "http" nếu dùng real HTTP server

# ─── Cấu hình Trace ───
TRACE_OUTPUT_DIR=./artifacts/traces
